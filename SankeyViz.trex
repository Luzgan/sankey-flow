<?xml version="1.0" encoding="utf-8"?>
<manifest manifest-version="0.1" xmlns="http://www.tableau.com/xml/extension_manifest">
  <worksheet-extension id="com.sankeyflow.extension.viz" extension-version="1.0.0">
    <default-locale>en_US</default-locale>
    <name resource-id="name"/>
    <description>Visualize how values flow, split, and merge across stages. Drag dimensions to Stage and a measure to Value to create a multi-stage Sankey diagram. Features gradient flows, 5+ color palettes, per-node color overrides, drop-off mode, smart labels, drag-to-reorder nodes, rich tooltips, SVG/PNG export, and full Tableau selection integration.</description>
    <author name="Lukasz Holc" email="luk.holc@gmail.com" organization="Sankey Flow" website="https://lukholc.me"/>
    <min-api-version>1.11</min-api-version>
    <source-location>
      <url>https://sankeyflow.lukholc.me/SankeyViz.html</url>
    </source-location>
    <icon></icon>
    <encoding id="level">
      <display-name>Stage</display-name>
      <role-spec>
        <role-type>discrete-dimension</role-type>
        <role-type>discrete-measure</role-type>
      </role-spec>
      <fields max-count="5"/>
    </encoding>
    <encoding id="edge">
      <display-name>Value</display-name>
      <role-spec>
        <role-type>continuous-measure</role-type>
        <role-type>continuous-dimension</role-type>
      </role-spec>
      <fields max-count="1"/>
    </encoding>
  </worksheet-extension>
  <resources>
    <resource id="name">
      <text locale="en_US">Sankey Flow</text>
    </resource>
  </resources>
</manifest> 