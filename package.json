{
  "name": "sankey-tableau-extension",
  "version": "1.0.0",
  "description": "A Tableau viz extension for creating interactive Sankey diagrams",
  "main": "SankeyViz.js",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "build:dev": "node esbuild.config.mjs --dev",
    "dev": "node esbuild.config.mjs --dev --watch",
    "dev:standalone": "npm run build:dev && node dev/server.mjs",
    "dev:tableau": "./dev/start-tableau.sh",
    "lint": "eslint '**/*.{ts,tsx}' --ignore-pattern '*.js'",
    "lint:fix": "eslint '**/*.{ts,tsx}' --ignore-pattern '*.js' --fix",
    "clean": "rm -f SankeyViz.js SankeyViz.js.map"
  },
  "keywords": [
    "tableau",
    "extension",
    "sankey",
    "visualization",
    "d3"
  ],
  "author": "Sankey Extension Developer",
  "license": "MIT",
  "devDependencies": {
    "@tableau/extensions-api-types": "^1.15.0",
    "@types/d3": "^7.4.3",
    "@types/d3-sankey": "^0.12.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/tinycolor2": "^1.4.3",
    "esbuild": "^0.27.3",
    "eslint": "^8.47.0",
    "typescript": "^4.9.0"
  },
  "dependencies": {
    "d3": "^7.8.5",
    "d3-sankey": "^0.12.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tinycolor2": "^1.6.0"
  }
}
