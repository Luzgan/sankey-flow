{
  "name": "sankey-tableau-extension",
  "version": "1.0.0",
  "description": "A Tableau viz extension for creating interactive Sankey diagrams",
  "main": "SankeyViz.js",
  "scripts": {
    "build": "webpack",
    "build:dev": "webpack --mode=development",
    "build:deploy": "webpack && npm run copy-files",
    "copy-files": "./copy-files.sh",
    "dev": "webpack --watch --mode=development",
    "dev:full": "concurrently \"npm run dev\" \"npm run copy-files:watch\"",
    "copy-files:watch": "nodemon --watch SankeyViz.html --watch SankeyViz.js --watch SankeyViz.trex --watch SankeyConfig.html --watch SankeyConfig.js --watch sample-data.csv --exec \"npm run copy-files\"",
    "start:dev": "npm run dev:full",
    "lint": "eslint SankeyViz.ts",
    "lint:fix": "eslint SankeyViz.ts --fix",
    "clean": "rm -f SankeyViz.js SankeyViz.js.map SankeyConfig.js SankeyConfig.js.map"
  },
  "keywords": [
    "tableau",
    "extension",
    "sankey",
    "visualization",
    "d3"
  ],
  "author": "Sankey Extension Developer",
  "license": "MIT",
  "devDependencies": {
    "@tableau/extensions-api-types": "^1.15.0",
    "@types/d3": "^7.4.3",
    "@types/d3-sankey": "^0.12.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/tinycolor2": "^1.4.3",
    "concurrently": "^8.2.2",
    "eslint": "^8.47.0",
    "nodemon": "^3.0.1",
    "ts-loader": "^9.5.2",
    "typescript": "^4.9.0",
    "webpack": "^5.100.1",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "d3": "^7.8.5",
    "d3-sankey": "^0.12.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tinycolor2": "^1.6.0"
  }
}
